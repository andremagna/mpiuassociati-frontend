@model m_associati.Models.Infrastrutturale

@{
    ViewBag.Title = "DettagliCivile";
}


<head>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
</head>

<section class="et-hero-tabs" style="background-image: url(@Model.Copertina)">
    <h1>@Model.Progetto - @Model.Luogo</h1>
    <h3>Un progetto realizzato dallo studio M+ Associati</h3>
    <img class='trigger' src='~/Images/generals/arrow.png' style="width:30px; margin-top:5%">
    <div class="et-hero-tabs-container">
        <a class="et-hero-tab" href="#tab-es6">Galleria Fotografica</a>
        <a class="et-hero-tab" href="#tab-flexbox">Descizione del Progetto</a>
        <a class="et-hero-tab" href="#tab-react">Mappa Satellitare</a>
        @*<a class="et-hero-tab" href="#tab-angular">Mappa Satellitare</a>*@
        @*<a class="et-hero-tab" href="#tab-other">Other</a>*@
        <span class="et-hero-tab-slider"></span>
    </div>
</section>

<main class="et-main">
    <section class="et-slide" id="tab-es6">
        <h1>Galleria Fotografica</h1>
        <div class="container-box-img">
            <div class="box-img" style="background-image: url(@Model.Immagini[0])"> </div>
            <div class="box-img" style="background-image: url(@Model.Immagini[1])"> </div>
            <div class="box-img" style="background-image: url(@Model.Immagini[2])"> </div>
            <div class="box-img" style="background-image: url(@Model.Immagini[3])"> </div>
            <div class="box-img" style="background-image: url(@Model.Immagini[4])"> </div>
            <div class="box-img" style="background-image: url(@Model.Immagini[5])"> </div>
        </div>
    </section>

    <section class="et-slide" id="tab-flexbox">
        <h1>Descrizione del Progetto</h1>
        <h3>@Model.DescrizioneProgetto</h3>
        <h4> Planimetria del Progetto (PDF) </h4>
    </section>

    <section class="et-slide" id="tab-react">
        <h1>Mappa Satellitare</h1>
        <iframe src="https://maps.google.com/maps?q=@Model.Latitudine,@Model.Longitudine&hl=it&z=11&amp;output=embed" width="100%" height="100%" frameborder="0" style="border:0" allowfullscreen></iframe>
    </section>

    @*<section class="et-slide" id="tab-angular">
            <h1>Angular</h1>
            <h3>something about angular</h3>
        </section>
        <section class="et-slide" id="tab-other">
            <h1>Other</h1>
            <h3>something about other</h3>
        </section>*@
    <script src="~/Content/app/js/dettagliProgetti.js"></script>
</main>

<footer>
    <p padding: 0 4%"> <b> &copy; @DateTime.Now.Year - M+ Associati - Via Guido Gozzano 6, Seregno (MB) Italy - P.Iva 06827510964</b> </p>
</footer>