@model List<frontend.Models.Projects>

@{
    ViewBag.Title = "INostriProgetti";
}

@*<head>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/modernizr/2.8.3/modernizr.min.js" type="text/javascript"></script>
    <link rel='stylesheet' href='https://netdna.bootstrapcdn.com/font-awesome/4.0.3/css/font-awesome.css'>
</head>*@

<div id="main_bachecaprogettiS">
    <main id="main_bachecaprogetti">
        <div class="left_side">
            <h1 style="color: whitesmoke; font-family: 'Abril Fatface', serif;">Direzione Lavori</h1>
            <h4 style="color: whitesmoke">Do you need the coolest and the most awesome platform to manage your project?! You have walked to the right place!</h4>
        </div>
    </main>
</div>

<div id="app" style="background-color: white">
    <div data-reactroot="">
        <div id="content">
            <div id="page">
                <div id="page-content" class="">
                    <div id="projects-page">
                        <div class="projects-container">
                            <div class="projects">
                                @foreach (var proj in Model)
                                {
                                    <a class="project-item" href="DettagliAeroportuale/@proj.Id">
                                        <div class="project-item-image">
                                            <div class="single-media gallery-component">
                                                <figure class="media" style="background-image:url(@proj.ProjectCover)">
                                                    <figcaption>
                                                        © M+ Associati
                                                    </figcaption>
                                                </figure>
                                            </div>
                                        </div>
                                        <h1 class="subtitle" style="margin:10px 0">@proj.ProjectName</h1>
                                        <h2 class="subtitle" style="margin:0">@proj.ProjectPlace</h2>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>